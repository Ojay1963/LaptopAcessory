NODE_ENV=production
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=oj-devices-api
JWT_AUDIENCE=oj-devices-client
JWT_EXPIRES_IN_HOURS=24
REFRESH_TOKEN_DAYS=14

# Seed admin
ADMIN_EMAIL=admin@ojdevices.ng
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=OJ Devices Admin

# OTP and email via Brevo
OTP_TTL_MINUTES=10
BREVO_API_KEY=
BREVO_SENDER_EMAIL=support@ojdevices.ng
BREVO_SENDER_NAME=OJ Devices

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:5173/checkout/callback

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=oj-devices
