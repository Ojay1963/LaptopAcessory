{
  "name": "oj-devices-store",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "build:client": "npm run build --workspace client",
    "lint": "npm run lint --workspace client && npm run lint --workspace server",
    "lint:client": "npm run lint --workspace client",
    "lint:server": "npm run lint --workspace server",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
